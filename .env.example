# Fixio environment example
# Copy this to .env and fill in real values before running the app.

NODE_ENV=development
APP_NAME=Fixio
PORT=3000
FRONTEND_ORIGIN=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=fixio_db

JWT_ACCESS_SECRET=replace-with-a-secure-access-secret-of-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-secure-refresh-secret-of-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
